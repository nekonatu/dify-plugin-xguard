# ── Dify Plugin Remote Debugging ──
INSTALL_METHOD=remote
REMOTE_INSTALL_HOST=localhost
REMOTE_INSTALL_PORT=5003
REMOTE_INSTALL_KEY=your-dify-plugin-key-here

# ── XGuard Server Configuration ──
# Used by server/app.py (prefix: XGUARD_)
XGUARD_MODEL_DIR=./YuFeng-XGuard-Reason-0.6B
XGUARD_DEVICE=auto
XGUARD_LISTEN_HOST=0.0.0.0
XGUARD_LISTEN_PORT=8001
XGUARD_DEFAULT_RISK_THRESHOLD=0.5
XGUARD_TOP_TOKEN_COUNT=20
